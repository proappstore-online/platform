{
  "name": "proappstore-platform-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Paid SDK + CLI + backend for apps published on proappstore.online",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proappstore-online/platform.git"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "ws@>=8.0.0 <8.21.0": ">=8.21.0",
      "undici@>=7.23.0 <7.28.0": ">=7.28.0 <8"
    }
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "mermaid": "^11.4.1",
    "typescript": "^5.7.0",
    "vitepress": "^1.5.0",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^2.1.0"
  }
}
